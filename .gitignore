# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Cursor metadata / MCP (may contain tokens)
.cursor/

# Python
/python/.venv
/python/__pycache__/
/python/**/*.pyc

# Local data (raw/processed/models) generated by pipeline
/data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# iOS / Android build artifacts
/ios/Pods/
/ios/build/
/android/.gradle/
/android/app/build/
