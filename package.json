{
  "name": "kinetic-logic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:mobile": "BUILD_FOR_CAPACITOR=1 next build && npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "cap:sync": "npx cap sync",
    "python:setup": "cd python && python -m venv .venv && node ../scripts/run-python.js -m pip install -r requirements.txt",
    "python:process": "node scripts/run-python.js process.py",
    "python:train": "node scripts/run-python.js train.py",
    "python:evaluate": "node scripts/run-python.js evaluate.py",
    "python:fixture": "node scripts/run-python.js make_fixture.py"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^7.6.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/motion": "^8.0.0",
    "@supabase/supabase-js": "^2.99.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
